# ── Nodus Backend API ─────────────────────────────────────────────────────────
# Base URL for the Nodus Protocol Backend API (no trailing slash).
API_BASE_URL=http://localhost:8080

# ── Stellar Network ───────────────────────────────────────────────────────────
# "testnet" or "mainnet"
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── Pool Contract ─────────────────────────────────────────────────────────────
POOL_CONTRACT_ID=
POOL_TOKEN_0=XLM
POOL_TOKEN_1=USDC

# ── Firebase (optional — crash reporting and analytics) ───────────────────────
# Set these if you have a Firebase project configured.
# FIREBASE_PROJECT_ID=
# FIREBASE_APP_ID=
